# Groq API key — get one at https://console.groq.com
GROQ_API_KEY=

# LLM — llama-3.1-8b-instant is fastest for voice
GROQ_MODEL=llama-3.1-8b-instant

# STT via Groq cloud (recommended). Use STT_PROVIDER=local for offline CPU whisper
STT_PROVIDER=groq
GROQ_WHISPER_MODEL=whisper-large-v3

# Optional: custom agent prompts YAML (default: config/prompts/aether_knight.yaml)
# AGENT_PROMPTS_FILE=config/prompts/aether_knight.yaml

# Local whisper fallback
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Audio uploads
TEMP_DIR=temp
MAX_AUDIO_SIZE_MB=25
